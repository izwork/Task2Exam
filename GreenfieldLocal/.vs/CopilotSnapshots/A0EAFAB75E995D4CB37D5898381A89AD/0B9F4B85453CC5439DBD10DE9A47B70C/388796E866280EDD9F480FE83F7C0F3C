@model GreenfieldLocal.Models.Suppliers

@{
    ViewData["Title"] = "Create";
}

<h1>Create</h1>

<h4>Suppliers</h4>
<hr />
<div class="row">
    <div class="col-md-6">
        <div class="card shadow-sm mb-4">
            <div class="card-body">
                <form asp-action="Create" class="needs-validation" novalidate>
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="UserId" class="form-label"></label>
                        <input asp-for="UserId" class="form-control" />
                        <span asp-validation-for="UserId" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="SupplierName" class="form-label"></label>
                        <input asp-for="SupplierName" class="form-control" placeholder="Enter supplier name" />
                        <span asp-validation-for="SupplierName" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="SupplierEmail" class="form-label"></label>
                        <input asp-for="SupplierEmail" class="form-control" type="email" placeholder="name@company.com" />
                        <span asp-validation-for="SupplierEmail" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="SupplierInformation" class="form-label"></label>
                        <textarea asp-for="SupplierInformation" class="form-control" rows="4" placeholder="Additional information about the supplier"></textarea>
                        <span asp-validation-for="SupplierInformation" class="text-danger"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <input type="submit" value="Create" class="btn btn-primary" />
                        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
