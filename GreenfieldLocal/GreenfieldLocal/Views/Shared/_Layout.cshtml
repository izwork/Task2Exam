<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - GreenfieldLocal</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/GreenfieldLocal.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/StyleSheet.css" asp-append-version="true" />
    <!-- JavaScript & Bootstrap -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/Accessibility.js"></script>
</head>
<body>
    <!-- toggle button (always visible) -->
    <button id="accessibility-toggle"
            class="accessibility-toggle"
            aria-controls="accessibility-sidebar"
            aria-expanded="false"
            title="Accessibility options">
        <img src="~/images/accessibility-icon.png" alt="Accessibility" />
    </button>

    <!-- overlay shown when sidebar is open -->
    <div id="accessibility-overlay" class="sr-only" tabindex="-1" aria-hidden="true"></div>

    <div id="accessibility-sidebar" aria-hidden="true" role="region" aria-label="Accessibility tools">
        <button onclick="toggleDarkMode()" title="Toggle Dark Mode">
            <img src="~/images/dark-mode.png" alt="Toggle Dark Mode" />
            <span class="label">Dark mode</span>
        </button>

        <button onclick="changeFontSize('increase')" title="Increase Font Size">
            <img src="~/images/text-increase.png" alt="Increase Font Size" />
            <span class="label">Increase text</span>
        </button>

        <button onclick="changeFontSize('decrease')" title="Decrease Font Size">
            <img src="~/images/text-decrease.png" alt="Decrease Font Size" />
            <span class="label">Decrease text</span>
        </button>

        <button onclick="toggleHighContrast()" title="High Contrast Mode">
            <img src="~/images/high-contrast.png" alt="High Contrast Mode" />
            <span class="label">High contrast</span>
        </button>

        <button onclick="speakText()" title="Read Aloud">
            <img src="~/images/speak-text.png" alt="Read Aloud" />
            <span class="label">Read aloud</span>
        </button>

        <!-- RESET button -->
        <button onclick="resetAccessibility()" title="Reset accessibility settings" class="reset-button">
            <img src="~/images/reset.png" alt="Reset settings" />
            <span class="label">Reset</span>
        </button>
    </div>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">GreenfieldLocal</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Products" asp-action="Index">Products</a>
                        </li>
                        @if (User.IsInRole("Standard"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-area="" asp-controller="Baskets" asp-action="Index">View Basket</a>
                            </li>
                        }
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Orders" asp-action="Index">View Orders</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Suppliers" asp-action="Index">Suppliers</a>
                        </li>
                    </ul>
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - GreenfieldLocal - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
