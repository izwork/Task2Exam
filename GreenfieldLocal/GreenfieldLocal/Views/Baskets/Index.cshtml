@model IEnumerable<GreenfieldLocal.Models.BasketProducts>

@{
    ViewData["Title"] = "Your Basket";
    var basketId = Model.FirstOrDefault()?.BasketId;
}

<h1 class="mb-4">Your Basket</h1>

@if (!Model.Any())
{
    <div class="empty-basket-card p-4 rounded">
        <div class="d-flex align-items-center gap-3">
            <div class="empty-basket-icon">
                <img src="~/images/cart-icon.png" />
            </div>
            <div>
                <h3 class="mb-1">Your basket is empty</h3>
                <p class="mb-2 text-muted">Looks like you haven't added any products yet.</p>
                <a asp-controller="Products" asp-action="Index" class="btn btn-continue">Continue shopping</a>
            </div>
        </div>
    </div>
}
else
{
    <div class="row">
        <div class="col-lg-8">
            @foreach (var item in Model)
            {
                <div class="basket-card mb-3 p-3 d-flex align-items-center">
                    <img src="@(item.Products.ImagePath ?? "~/images/placeholder.png")"
                         alt="@item.Products.ProductName"
                         class="basket-item-img me-3" />
                    <div class="flex-grow-1">
                        <h5 class="mb-1">@item.Products.ProductName</h5>
                        <div class="text-muted mb-2">Price: £@item.Products.Price.ToString("0.00")</div>
                        <div class="d-flex align-items-center mb-2">
                            <span class="qty-display">Qty: @item.Quantity</span>
                                    <form asp-controller="BasketProducts" asp-action="DecreaseQuantity" asp-route-id="@item.BasketProductsId" method="post" class="d-inline me-1">
                                        <button type="submit" class="btn btn-sm btn-outline-secondary">-</button>
                                    </form>
                                    <form asp-controller="BasketProducts" asp-action="IncreaseQuantity" asp-route-id="@item.BasketProductsId" method="post" class="d-inline">
                                        <button type="submit" class="btn btn-sm btn-primary">+</button>
                                    </form>
                        </div>
                        <div>
                            <span class="fw-semibold">Total: £@((item.Products.Price * item.Quantity).ToString("0.00"))</span>
                        </div>
                    </div>
                </div>
            }
        </div>
        <div class="col-lg-4">
            <div class="order-summary-card p-4 mb-3">
                <h3 class="mb-3">Order Summary</h3>
                <div class="d-flex justify-content-between mb-2">
                    <span>Subtotal:</span>
                    <span>£@(((decimal)ViewBag.Subtotal).ToString("0.00"))</span>
                </div>
                <div class="d-flex justify-content-between mb-2">
                    <span>Loyalty Discount:</span>
                    <span>-£@(((decimal)ViewBag.Discount).ToString("0.00"))</span>
                </div>
                <hr />
                <div class="d-flex justify-content-between mb-3">
                    <strong>Total:</strong>
                    <strong>£@(((decimal)ViewBag.Total).ToString("0.00"))</strong>
                </div>
                @if (ViewBag.Discount > 0)
                {
                    <div class="alert alert-success py-2">
                        Your loyalty discount has been applied.
                    </div>
                }
                <a asp-controller="Orders"
                   asp-action="Create"
                   asp-route-basketId="@basketId"
                   class="btn btn-primary w-100 mb-2">
                    Proceed to Checkout
                </a>
                <a asp-controller="Products"
                   asp-action="Index"
                   class="btn btn-continue w-100">
                    Continue Shopping
                </a>
                <form asp-controller="Baskets" asp-action="Delete" asp-route-id="@basketId" method="post" class="mt-3">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger w-100">Delete Basket</button>
                </form>
            </div>
        </div>
    </div>
}

@section Scripts {
<script>
    function increaseQuantity(basketProductId) {
        fetch(`/BasketProducts/IncreaseQuantity/${basketProductId}`, { method: 'POST' })
            .then(response => {
                if (response.ok) {
                    location.reload(); // Reload to reflect changes
                }
            });
    }
</script>
}
