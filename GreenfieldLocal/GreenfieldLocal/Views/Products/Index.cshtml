@model IEnumerable<GreenfieldLocal.Models.Products>

@{
    ViewData["Title"] = "Index";
}

<h1>All Products</h1>

@if (User.IsInRole("Admin") || User.IsInRole("Developer") || User.IsInRole("Supplier"))
{
    <p>
        <button> <a asp-action="Create" class="btn-lol">Create New</a> </button>
    </p>
}
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.ProductName)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Stock)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Price)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.ImagePath)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Suppliers)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model) {
            <tr>
                <td>
                    @Html.DisplayFor(modelItem => item.ProductName)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Stock)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Price)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.ImagePath)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Suppliers.SuppliersId)
                </td>
                <td>
                    <button> <a asp-action="Details" asp-route-id="@item.ProductsId" class="btn-lol">Details</a> </button>

                    @if (User.IsInRole("Admin") || User.IsInRole("Developer") || User.IsInRole("Supplier"))
                    {
                        <button style="background-color:#988C84; border-color:#988C84; border-radius:8px"> <a asp-action="Edit" asp-route-id="@item.ProductsId" class="btn-lol">Edit</a> </button>
                        <button style="background-color:#988C84; border-color:#988C84; border-radius:8px"> <a asp-action="Delete" asp-route-id="@item.ProductsId" class="btn-lol">Delete</a> </button>
                    }

                    <form asp-controller="BasketProducts" asp-action="Create" method="post">
                        <input type="hidden" name="ProductsId" value="@item.ProductsId" />

                        @if (item.Stock > 0)
                        {
                            <button type="submit" class="btn btn-primary w-100">
                                Add to Basket
                            </button>
                        }
                        else
                        {
                            <button type="button" class="btn btn-secondary w-100" disabled>
                                Out of Stock
                            </button>
                        }
                    </form>
                </td>
        </tr>
}
    </tbody>
</table>
