@model GreenfieldLocal.Models.Products

@{
    ViewData["Title"] = Model?.ProductName ?? "Product Details";
}

@if (Model == null)
{
    <div class="alert alert-warning">Product not found.</div>
}
else
{
    <div class="card mb-4 shadow-sm">
        <div class="row g-0">
            <div class="col-md-4 d-flex align-items-center justify-content-center p-3">
                <img src="@(Model.ImagePath ?? "/images/placeholder.png")" class="img-fluid rounded" alt="@Model.ProductName" />
            </div>
            <div class="col-md-8">
                <div class="card-body d-flex flex-column h-100">
                    <h2 class="card-title">@Model.ProductName</h2>
                    <h5 class="text-muted">@Model.Price.ToString("C")</h5>
                    <p class="mb-2"><strong>Stock:</strong> @Model.Stock</p>
                    @if (Model.Suppliers != null)
                    {
                        <p class="mb-2"><strong>Supplier:</strong> @Model.Suppliers.SupplierName</p>
                    }
                    <div class="mt-auto">
                        <a asp-action="Index" class="btn btn-outline-primary me-2">Back to Products</a>

                        @if (User.IsInRole("Admin") || User.IsInRole("Developer") || User.IsInRole("Supplier"))
                        {
                            <a asp-action="Edit" asp-route-id="@Model.ProductsId" class="btn btn-secondary me-2">Edit</a>
                            <a asp-action="Delete" asp-route-id="@Model.ProductsId" class="btn btn-danger">Delete</a>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
}
