@model IEnumerable<GreenfieldLocal.Models.OrderProducts>

@{
    ViewData["Title"] = "Order Details";
    var firstItem = Model.FirstOrDefault();
}

<h1>Order Details</h1>

@if (firstItem != null)
{
    <div>
        <p><strong>Order Id:</strong>@firstItem.Orders.OrdersId</p>
        <p><strong>Order Date:</strong>@firstItem.Orders.OrderDate</p>
        <p><strong>Status:</strong>@firstItem.Orders.OrderTrackingStatus</p>
        <p><strong>Subtotal:</strong>@firstItem.Orders.Subtotal.ToString("0.00")</p>

        @if (firstItem.Orders.Delivery)
        {
            <p><strong>Order Method:</strong>Delivery</p>
            <p><strong>Delivery Type:</strong>@firstItem.Orders.DeliveryType</p>
        }

        @if (firstItem.Orders.Collection)
        {
            <p><strong>Order Method:</strong>Collection</p>
            <p><strong>Collection Date:</strong>@firstItem.Orders.CollectionDate</p>
        }
    </div>

    <hr />

    <h2>Products in this Order</h2>

    <table>
        <thead>
            <tr>
                <th styele="text-align:left; padding-right:20px;">Product</th>
                <th styele="text-align:left; padding-right:20px;">Price</th>
                <th styele="text-align:left; padding-right:20px;">Quantity</th>
                <th styele="text-align:left; padding-right:20px;">Line Total</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td styele="text-align:left; padding-right:20px;">@item.Products.ProductName</td>
                    <td styele="text-align:left; padding-right:20px;">@item.Products.Price.ToString("0.00")</td>
                    <td styele="text-align:left; padding-right:20px;">@item.Quantity</td>
                    <td styele="text-align:left; padding-right:20px;">@((item.Products.Price * item.Quantity).ToString("0.00"))</td>
                </tr>
            }
        </tbody>
    </table>
}

<div style="margin-top:20px;">
    <a asp-action="Index">Back to List</a>"
</div>