@model IEnumerable<GreenfieldLocal.Models.OrderProducts>

@{
    ViewData["Title"] = "Order Details";
    var order = Model.FirstOrDefault()?.Orders;
}

<h1 class="mb-4">Order Details</h1>

@if (order == null)
{
    <div class="alert alert-warning">Order not found.</div>
}
else
{
    <div class="card order-details-card mb-4">
        <div class="card-body">
            <div class="d-flex flex-column flex-md-row justify-content-between gap-3">
                <div>
                    <h5 class="mb-1">Order #@order.OrdersId</h5>
                    <div class="text-muted small">Placed</div>
                    <div class="fw-bold mb-2">@order.OrderDate.ToString("dd MMM yyyy")</div>

                    <div class="text-muted small">Status</div>
                    <div class="fw-bold mb-2">@order.OrderTrackingStatus</div>

                    @if (order.Delivery)
                    {
                        <div class="text-muted small">Delivery</div>
                        <div class="mb-1">@order.DeliveryType</div>
                    }
                    else if (order.Collection)
                    {
                        <div class="text-muted small">Collection</div>
                        <div class="mb-1">@order.CollectionDate?.ToString("dd MMM yyyy")</div>
                    }
                </div>

                <div class="text-md-end">
                    <div class="text-muted small">Subtotal</div>
                    <div class="h4 fw-bold">@order.Subtotal.ToString("C")</div>
                    <div class="mt-3">
                        <a asp-action="Index" class="btn btn-outline-secondary btn-sm me-2">Back</a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <h2 class="h5 mb-3">Products in this order</h2>

    <div class="table-responsive">
        <table class="table align-middle order-items-table">
            <thead class="table-light">
                <tr>
                    <th style="width:50%;">Product</th>
                    <th style="width:15%;">Price</th>
                    <th style="width:10%;">Qty</th>
                    <th style="width:15%;">Line total</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <div class="d-flex align-items-center">
                                <img src="@(Url.Content(item.Products.ImagePath ?? "~/images/placeholder.png"))" alt="@item.Products.ProductName" class="order-item-img me-3" />
                                <div>
                                    <div class="fw-semibold">@item.Products.ProductName</div>
                                    <div class="text-muted small">@item.Products?.Suppliers?.SupplierName</div>
                                </div>
                            </div>
                        </td>
                        <td>@item.Products.Price.ToString("C")</td>
                        <td>@item.Quantity</td>
                        <td>@((item.Products.Price * item.Quantity).ToString("C"))</td>
                    </tr>
                }
            </tbody>
            <tfoot>
                <tr>
                    <td></td>
                    <td></td>
                    <td class="text-end fw-semibold">Total:</td>
                    <td class="fw-bold">@order.Subtotal.ToString("C")</td>
                </tr>
            </tfoot>
        </table>
    </div>
}