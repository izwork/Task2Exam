@model IEnumerable<GreenfieldLocal.Models.Orders>

@{
    ViewData["Title"] = "Orders";
}

<h1 class="mb-4">All Orders</h1>

@if (!Model.Any())
{
    <div class="empty-basket-card p-4 rounded">
        <div class="d-flex align-items-center gap-3">
            <div class="empty-basket-icon">
                <img src="~/images/shopping-icon.png" />
            </div>
            <div>
                <h3 class="mb-1">You have no orders yet!</h3>
                <p class="mb-2 text-muted">Looks like you haven't purchased anything.</p>
                <a asp-controller="Products" asp-action="Index" class="btn btn-continue">Continue shopping</a>
            </div>
        </div>
    </div>
}
else
{
    <div class="row">
        @foreach (var order in Model)
        {
            <div class="col-12 col-sm-6 col-md-4 mb-4">
                <div class="card order-card h-100">
                    <div class="card-body d-flex flex-column">
                        <div class="mb-2">
                            <small class="text-muted">Order date</small>
                            <div class="fw-bold">@order.OrderDate.ToString("dd MMM yyyy")</div>
                        </div>

                        <div class="mb-2">
                            <small class="text-muted">Status</small>
                            <div class="fw-bold">@order.OrderTrackingStatus</div>
                        </div>

                        <div class="mb-2">
                            <small class="text-muted">Order type</small>
                            <div class="fw-bold">
                                @if (order.Delivery)
                                {
                                    @("Delivery" + (string.IsNullOrWhiteSpace(order.DeliveryType) ? "" : " - " + order.DeliveryType))
                                }
                                else if (order.Collection)
                                {
                                    @("Collection" + (order.CollectionDate.HasValue ? " - " + order.CollectionDate.Value.ToString("dd MMM yyyy") : ""))
                                }
                                else
                                {
                                    @("-")
                                }
                            </div>
                        </div>

                        <div class="mb-3">
                            <small class="text-muted">Cost</small>
                            <div class="fw-bold">@order.Subtotal.ToString("C")</div>
                        </div>

                        <div class="mt-auto">
                            <a asp-action="Details" asp-route-id="@order.OrdersId" class="btn btn-outline-primary w-100">View details</a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
