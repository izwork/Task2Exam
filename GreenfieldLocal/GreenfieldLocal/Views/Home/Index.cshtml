@{
    ViewData["Title"] = "Home Page";
}

<section class="hero-section mb-5">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-md-7 text-center text-md-start text-white py-5">
                <h1 class="display-4 fw-bold">Freshness You Can Taste, Quality You Can Trust.</h1>
                <p class="lead mb-4">Love the farmers market but hate the early morning crowds? We bring the best of the stalls straight to your kitchen. From crisp greens to sun-ripened orchard fruits, our website makes eating local as easy as clicking a button. Support your neighbors and skip the supermarket lines—all in one delivery.</p>
                <div class="d-flex gap-3 justify-content-center justify-content-md-start">
                    <a asp-controller="Products" asp-action="Index" class="btn btn-outline-light btn-lg px-4">Browse All</a>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .hero-section {
        background: linear-gradient(rgba(2, 48, 32, 0.55), rgba(2, 48, 32, 0.2)), url('/images/field.jpg');
        background-size: cover;
        background-position: center;
        min-height: 420px;
        display: flex;
        align-items: center;
        color: white;
    }

    .feature-card {
        transition: transform .18s ease, box-shadow .18s ease;
    }

    .feature-card:hover {
        transform: translateY(-6px);
        box-shadow: 0 6px 20px rgba(0,0,0,0.12);
    }

    .benefit-title {
        font-weight: 600;
    }
</style>

<div class="container mb-5">
    <h3 class="mb-4">Why buy locally?</h3>
    <div class="row g-4">
        <div class="col-md-4">
            <div class="card feature-card h-100">
                <div class="card-body">
                    <h5 class="benefit-title">Boosts Local Economy</h5>
                    <p class="text-muted mb-0">Money spent locally tends to stay within the community, supporting farms and producers rather than distant corporations.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card feature-card h-100">
                <div class="card-body">
                    <h5 class="benefit-title">Superior Quality & Freshness</h5>
                    <p class="text-muted mb-0">Local food is fresher and more nutritious because it is harvested at peak and travels shorter distances.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card feature-card h-100">
                <div class="card-body">
                    <h5 class="benefit-title">Supports Sustainability</h5>
                    <p class="text-muted mb-0">Local producers often use sustainable practices that protect soil health and reduce transport emissions.</p>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="container mb-5">
    <div class="row align-items-center">
        <div class="col-md-6">
            <h3>What we do</h3>
            <p class="text-muted">Forget the flavorless, travel-weary produce from the big-box aisles. At Greenfield Local Hub, we believe that food should taste like where it came from. By partnering with the best local growers in our region, we bring you heirloom tomatoes that actually smell like summer, greens that crunch with life, and seasonal fruits picked at the peak of ripeness. We’ve shortened the supply chain to just a few miles, ensuring that what was in the ground yesterday is on your table today. Experience the vibrant, unmatched flavor of truly fresh food, delivered straight to your door.</p>
        </div>
        <div class="col-md-6">
            <div class="ratio ratio-16x9">
                <img src="/images/produce.jpg" alt="Fresh produce" class="img-fluid rounded" />
            </div>
        </div>
    </div>
</div>

        