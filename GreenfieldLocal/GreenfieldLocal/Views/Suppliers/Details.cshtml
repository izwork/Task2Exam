@model GreenfieldLocal.Models.Suppliers

@{
    ViewData["Title"] = Model?.SupplierName ?? "Supplier Details";
}

@if (Model == null)
{
    <div class="alert alert-warning">Supplier not found.</div>
}
else
{
    <div class="card mb-4 shadow-sm">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <h2 class="card-title mb-1">@Model.SupplierName</h2>
                    <h6 class="card-subtitle text-muted mb-3">@Model.SupplierEmail</h6>
                </div>
                <div class="text-end">
                    @if (User.IsInRole("Admin") || User.IsInRole("Developer"))
                    {
                        <a asp-action="Edit" asp-route-id="@Model.SuppliersId" class="btn btn-secondary me-2">Edit</a>
                        <a asp-action="Delete" asp-route-id="@Model.SuppliersId" class="btn btn-danger">Delete</a>
                    }
                </div>
            </div>

            <hr />

            <p class="card-text">@Model.SupplierInformation</p>

            <div class="mt-3">
                <a asp-action="Index" class="btn btn-outline-primary">Back to Suppliers</a>
            </div>
        </div>
    </div>
}
