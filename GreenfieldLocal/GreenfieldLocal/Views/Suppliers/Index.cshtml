@model IEnumerable<GreenfieldLocal.Models.Suppliers>

@{
    ViewData["Title"] = "Our Local Suppliers";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">@ViewData["Title"]</h1>
    @if (User.IsInRole("Admin") || User.IsInRole("Developer"))
    {
        <a asp-action="Create" class="btn btn-success">Create New</a>
    }
</div>

@if (Model == null || !Model.Any())
{
    <div class="alert alert-info">No suppliers available.</div>
}
else
{
    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-12 col-sm-6 col-md-4 mb-4">
                <div class="card h-100 shadow-sm">
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title">@item.SupplierName</h5>
                        <h6 class="card-subtitle mb-2 text-muted">@item.SupplierEmail</h6>
                        <p class="card-text">@item.SupplierInformation</p>
                        <div class="mt-auto">
                            <a asp-action="Details" asp-route-id="@item.SuppliersId" class="btn btn-outline-primary me-2" aria-label="View details for @item.SupplierName">Details</a>
                            @if (User.IsInRole("Admin") || User.IsInRole("Developer"))
                            {
                                <a asp-action="Edit" asp-route-id="@item.SuppliersId" class="btn btn-secondary me-2">Edit</a>
                                <a asp-action="Delete" asp-route-id="@item.SuppliersId" class="btn btn-danger">Delete</a>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
